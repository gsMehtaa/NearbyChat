<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F7"
    tools:context=".ChatroomActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/titleChatroom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chatroom"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#4EA3E3"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Messages"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvMessagesPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/drawing_box"
            android:gravity="center"
            android:text="Messages will appear here"
            android:textColor="#888888"
            android:textSize="18sp"
            android:padding="16dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnDrawingCanvas"
            android:layout_width="220dp"
            android:layout_height="50dp"
            android:text="Open Drawing Canvas"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Type a message..."
            android:inputType="text"
            android:padding="14dp"
            android:textSize="18sp"
            android:background="@drawable/device_box"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Send"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:weightSum="3">

        <Button
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Home"
            android:textAllCaps="false"
            android:textColor="#333333"
            android:background="@drawable/tab_unselected" />

        <Button
            android:id="@+id/tabChatroom"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Chatroom"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:background="@drawable/tab_selected" />

        <Button
            android:id="@+id/tabTools"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Tools"
            android:textAllCaps="false"
            android:textColor="#333333"
            android:background="@drawable/tab_unselected" />

    </LinearLayout>

</LinearLayout>